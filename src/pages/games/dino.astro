---
import GameLayout from '../../layouts/GameLayout.astro';
---
<GameLayout title="Chrome Dino Game">
  <div class="dino-wrapper">

    <!-- ── Settings ── -->
    <div class="settings-screen active" id="settings-screen">
      <h1 class="game-title">Chrome Dino Game</h1>
      <div class="settings-form">
        <label class="field">
          <span>Difficulty</span>
          <select id="difficulty-select">
            <option value="easy">Easy — slow pace, no birds</option>
            <option value="medium" selected>Medium — standard</option>
            <option value="hard">Hard — fast + birds</option>
          </select>
        </label>
      </div>
      <button class="btn-primary" id="start-btn">Start Game</button>
    </div>

    <!-- ── Game ── -->
    <div class="game-screen" id="game-screen">
      <div class="hud">
        <span class="hud-item">Score: <strong id="score-val">0</strong></span>
        <span class="hud-item">Best: <strong id="best-val">0</strong></span>
        <span class="hud-item diff-badge" id="diff-badge"></span>
      </div>

      <div class="canvas-wrap">
        <canvas id="dino-canvas" aria-label="Chrome Dino game"></canvas>
        <div class="overlay" id="overlay" hidden>
          <p id="overlay-msg"></p>
          <button class="btn-secondary" id="overlay-btn">Play Again</button>
        </div>
      </div>

      <div class="controls-row">
        <button class="btn-secondary" id="pause-btn">Pause</button>
        <button class="btn-secondary" id="settings-btn">Settings</button>
      </div>

      <div class="mobile-controls">
        <button class="mob-btn" id="duck-btn">↓ Duck</button>
        <button class="mob-btn" id="jump-btn">↑ Jump</button>
      </div>
    </div>

  </div>
</GameLayout>

<style is:global>
  html, body { margin: 0; min-height: 100%; }
  body {
    font-family: "Segoe UI", Tahoma, Geneva, Verdana, sans-serif;
    background:
      radial-gradient(circle at top left,  rgba(255,255,255,0.15), transparent 28%),
      radial-gradient(circle at bottom right, rgba(255,255,255,0.10), transparent 22%),
      linear-gradient(135deg, #c2410c, #7c2d12);
    min-height: 100dvh;
    color: #fff;
  }
</style>

<style>
  /* ── Layout ── */
  .dino-wrapper {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    min-height: 100dvh;
    padding: clamp(50px, 8vh, 76px) clamp(10px, 3vw, 24px) clamp(12px, 3vh, 28px);
    box-sizing: border-box;
  }

  /* ── Settings ── */
  .settings-screen {
    display: none; flex-direction: column; align-items: center;
    gap: 20px; width: 100%; max-width: 400px;
  }
  .settings-screen.active { display: flex; }
  .game-title {
    margin: 0; font-size: clamp(1.8rem, 5vw, 2.6rem);
    text-align: center; text-shadow: 0 3px 10px rgba(0,0,0,0.3);
  }
  .settings-form { display: flex; flex-direction: column; gap: 14px; width: 100%; }
  .field { display: flex; flex-direction: column; gap: 4px; font-size: 0.9rem; color: rgba(255,255,255,0.8); }
  select {
    background: rgba(255,255,255,0.12); border: 1px solid rgba(255,255,255,0.25);
    border-radius: 10px; color: #fff; padding: 10px 12px;
    font-size: 1rem; font-family: inherit; cursor: pointer;
    appearance: none; -webkit-appearance: none;
  }
  select option { background: #7c2d12; color: #fff; }

  /* ── Game screen ── */
  .game-screen {
    display: none; flex-direction: column; align-items: center;
    gap: clamp(6px, 1.4vh, 12px); width: 100%;
  }
  .game-screen.active { display: flex; }

  /* HUD */
  .hud {
    display: flex; gap: clamp(14px, 3vw, 28px); align-items: center;
    font-size: clamp(0.8rem, 2.4vw, 0.95rem);
    background: rgba(0,0,0,0.28); padding: 5px 18px; border-radius: 999px;
  }
  .diff-badge {
    font-size: 0.72rem; font-weight: 700; letter-spacing: 0.05em;
    padding: 2px 8px; border-radius: 999px; text-transform: uppercase;
  }
  .diff-badge.easy   { background: #22c55e33; color: #4ade80; }
  .diff-badge.medium { background: #f59e0b33; color: #fbbf24; }
  .diff-badge.hard   { background: #ef444433; color: #f87171; }

  /* Canvas */
  .canvas-wrap {
    position: relative;
    width: min(100vw - 20px, 800px);
    aspect-ratio: 4 / 1;
    border-radius: 14px; overflow: hidden;
    box-shadow: 0 10px 40px rgba(0,0,0,0.45);
  }
  @media (pointer: coarse) {
    .canvas-wrap {
      width: min(100vw - 20px, calc(100dvh - 280px));
    }
  }
  #dino-canvas { display: block; width: 100%; height: 100%; }

  /* Overlay */
  .overlay {
    position: absolute; inset: 0; background: rgba(0,0,0,0.65);
    display: flex; flex-direction: column; align-items: center;
    justify-content: center; gap: 16px; border-radius: 14px;
  }
  .overlay[hidden] { display: none; }
  #overlay-msg {
    margin: 0; font-size: clamp(1rem, 4vw, 1.4rem);
    font-weight: 700; text-align: center; padding: 0 16px; white-space: pre-line;
  }

  /* Buttons row */
  .controls-row { display: flex; gap: 12px; }

  /* Mobile jump/duck buttons */
  .mobile-controls { display: none; gap: 16px; width: min(100vw - 20px, 800px); }
  @media (pointer: coarse) {
    .mobile-controls { display: flex; }
  }
  .mob-btn {
    flex: 1; min-height: 56px;
    background: rgba(255,255,255,0.14); border: 1px solid rgba(255,255,255,0.2);
    border-radius: 14px; color: #fff; font-size: 1rem; font-weight: 700;
    font-family: inherit; cursor: pointer;
    -webkit-tap-highlight-color: transparent; user-select: none;
    touch-action: manipulation; transition: background 0.1s;
  }
  .mob-btn:active { background: rgba(255,255,255,0.32); }

  /* Shared button styles */
  .btn-primary, .btn-secondary {
    border: none; border-radius: 12px; font-family: inherit; font-weight: 600;
    cursor: pointer; transition: transform 0.15s, background 0.15s;
    -webkit-tap-highlight-color: transparent; min-height: 44px;
  }
  .btn-primary {
    background: #fbbf24; color: #7c2d12;
    font-size: 1.05rem; padding: 12px 28px; width: 100%;
  }
  .btn-primary:hover { transform: translateY(-2px); background: #f59e0b; }
  .btn-secondary {
    background: rgba(255,255,255,0.15); color: #fff;
    font-size: 0.9rem; padding: 10px 22px; border: 1px solid rgba(255,255,255,0.2);
  }
  .btn-secondary:hover { background: rgba(255,255,255,0.25); }

  /* Landscape phones */
  @media (orientation: landscape) and (max-height: 500px) {
    .dino-wrapper { padding: 8px 12px 8px clamp(44px, 10vw, 60px); }
    .canvas-wrap { width: min(calc(100dvh - 80px) * 4, 100vw - 20px); }
  }
</style>

<script is:inline>
(function () {
  /* ── DOM ── */
  const settingsScreen = document.getElementById('settings-screen');
  const gameScreen     = document.getElementById('game-screen');
  const startBtn       = document.getElementById('start-btn');
  const settingsBtn    = document.getElementById('settings-btn');
  const pauseBtn       = document.getElementById('pause-btn');
  const overlay        = document.getElementById('overlay');
  const overlayMsg     = document.getElementById('overlay-msg');
  const overlayBtn     = document.getElementById('overlay-btn');
  const scoreEl        = document.getElementById('score-val');
  const bestEl         = document.getElementById('best-val');
  const diffBadge      = document.getElementById('diff-badge');
  const canvas         = document.getElementById('dino-canvas');
  const ctx            = canvas.getContext('2d');
  const diffSel        = document.getElementById('difficulty-select');
  const jumpBtn        = document.getElementById('jump-btn');
  const duckBtn        = document.getElementById('duck-btn');

  /* ── Config ── */
  const DIFFICULTIES = {
    easy:   { startSpeed: 5,  maxSpeed: 9,  spawnMin: 80,  spawnMax: 130, birds: false, gravity: 0.65, jumpForce: -14 },
    medium: { startSpeed: 7,  maxSpeed: 14, spawnMin: 55,  spawnMax: 95,  birds: true,  gravity: 0.75, jumpForce: -15 },
    hard:   { startSpeed: 10, maxSpeed: 22, spawnMin: 38,  spawnMax: 65,  birds: true,  gravity: 0.85, jumpForce: -16 },
  };

  const DINO_COLOR   = '#1c1917';
  const CACTUS_COLOR = '#15803d';
  const BIRD_COLOR   = '#1c1917';
  const GROUND_COLOR = '#92400e';
  const SKY_TOP      = '#fef3c7';
  const SKY_BOT      = '#fde68a';

  /* ── State ── */
  let W, H, GROUND_Y;
  let speed, score, best, paused, gameOver, raf;
  let frameCount, spawnTimer;
  let dino, obstacles, clouds;
  let downHeld = false;
  let diff;

  best = parseInt(localStorage.getItem('dino-best') || '0', 10);
  bestEl.textContent = best;

  /* ── Canvas ── */
  function initCanvas() {
    W = canvas.parentElement.clientWidth;
    H = canvas.parentElement.clientHeight;
    canvas.width  = W;
    canvas.height = H;
    GROUND_Y = Math.floor(H * 0.78);
  }

  /* ── Dino helpers ── */
  function dinoW() { return dino.ducking ? 60 : 44; }
  function dinoH() { return dino.ducking ? 28 : 52; }
  function dinoBox() {
    const w = dinoW(), h = dinoH();
    return { x: dino.x + 4, y: dino.y - h + 2, w: w - 8, h: h - 4 };
  }

  /* ── Start ── */
  function startGame() {
    initCanvas();
    diff = DIFFICULTIES[diffSel.value];

    dino = { x: 80, y: GROUND_Y, vy: 0, onGround: true, ducking: false, legFrame: 0, legTick: 0 };
    obstacles = [];
    clouds = [];
    score = 0; frameCount = 0;
    speed = diff.startSpeed;
    paused = false; gameOver = false;
    spawnTimer = diff.spawnMin + Math.random() * (diff.spawnMax - diff.spawnMin);

    const diffKey = diffSel.value;
    diffBadge.textContent = diffKey;
    diffBadge.className   = `hud-item diff-badge ${diffKey}`;
    scoreEl.textContent   = '0';
    overlay.hidden        = true;
    pauseBtn.textContent  = 'Pause';

    // Seed some clouds
    for (let i = 0; i < 3; i++) {
      clouds.push({ x: Math.random() * W, y: 10 + Math.random() * (GROUND_Y * 0.4), r: 18 + Math.random() * 14 });
    }

    cancelAnimationFrame(raf);
    runCountdown(() => {
      raf = requestAnimationFrame(gameLoop);
    });
  }

  /* ── Countdown ── */
  function runCountdown(cb) {
    const steps = ['3', '2', '1', 'GO!'];
    let i = 0;
    function step() {
      drawScene();
      const label = steps[i], isGo = label === 'GO!';
      ctx.save();
      ctx.fillStyle = 'rgba(0,0,0,0.45)';
      ctx.fillRect(0, 0, W, H);
      ctx.textAlign = 'center'; ctx.textBaseline = 'middle';
      ctx.font = `bold ${Math.round(H * (isGo ? 0.38 : 0.52))}px "Segoe UI",sans-serif`;
      ctx.shadowColor = 'rgba(0,0,0,0.6)'; ctx.shadowBlur = 12;
      ctx.fillStyle = isGo ? '#fbbf24' : '#fff';
      ctx.fillText(label, W / 2, H / 2);
      ctx.restore();
      i++;
      if (i < steps.length) setTimeout(step, i === steps.length - 1 ? 650 : 850);
      else setTimeout(cb, 650);
    }
    step();
  }

  /* ── Game loop ── */
  function gameLoop() {
    if (paused || gameOver) return;
    frameCount++;

    // Speed ramp
    if (frameCount % 60 === 0) speed = Math.min(diff.maxSpeed, speed + 0.08);

    // Score
    score += speed / 10;
    const sc = Math.floor(score);
    scoreEl.textContent = sc;
    if (sc > best) { best = sc; bestEl.textContent = best; localStorage.setItem('dino-best', best); }

    updateDino();
    updateObstacles();
    updateClouds();

    if (checkCollisions()) { endGame(); return; }

    drawScene();
    raf = requestAnimationFrame(gameLoop);
  }

  /* ── Update dino ── */
  function updateDino() {
    // Ducking
    dino.ducking = downHeld && dino.onGround;

    // Gravity
    dino.vy += diff.gravity;
    dino.y  += dino.vy;

    if (dino.y >= GROUND_Y) {
      dino.y = GROUND_Y; dino.vy = 0; dino.onGround = true;
    }

    // Leg animation
    if (dino.onGround && !dino.ducking) {
      dino.legTick++;
      if (dino.legTick >= 8) { dino.legTick = 0; dino.legFrame ^= 1; }
    }
  }

  function jump() {
    if (dino.onGround && !dino.ducking) {
      dino.vy = diff.jumpForce;
      dino.onGround = false;
    }
  }

  /* ── Obstacles ── */
  const CACTUS_TYPES = [
    { w: 18, h: 46, kind: 'cactus' },
    { w: 24, h: 60, kind: 'cactus' },
    { w: 28, h: 70, kind: 'cactus' },
    { w: 54, h: 60, kind: 'cactus2' },
    { w: 66, h: 46, kind: 'cactus3' },
  ];

  function spawnObstacle() {
    const hasBirds = diff.birds && score > 200;
    const doBird = hasBirds && Math.random() < 0.35;

    if (doBird) {
      const altitudes = [
        GROUND_Y - 34,   // low — must duck
        GROUND_Y - 64,   // mid — jump or duck
        GROUND_Y - 96,   // high — run under
      ];
      const y = altitudes[Math.floor(Math.random() * altitudes.length)];
      obstacles.push({ kind: 'bird', x: W + 10, y, w: 46, h: 28, wingTick: 0, wingFrame: 0 });
    } else {
      const t = CACTUS_TYPES[Math.floor(Math.random() * CACTUS_TYPES.length)];
      obstacles.push({ ...t, x: W + 10, y: GROUND_Y });
    }
  }

  function updateObstacles() {
    spawnTimer -= 1;
    if (spawnTimer <= 0) {
      spawnObstacle();
      const range = diff.spawnMax - diff.spawnMin;
      const scale = diff.startSpeed / speed;
      spawnTimer = Math.round((diff.spawnMin + Math.random() * range) * scale);
      spawnTimer = Math.max(Math.floor(diff.spawnMin * 0.55), spawnTimer);
    }

    for (let i = obstacles.length - 1; i >= 0; i--) {
      const o = obstacles[i];
      o.x -= speed;
      if (o.kind === 'bird') {
        o.wingTick++;
        if (o.wingTick >= 15) { o.wingTick = 0; o.wingFrame ^= 1; }
      }
      if (o.x + o.w < -10) obstacles.splice(i, 1);
    }
  }

  /* ── Clouds ── */
  function updateClouds() {
    for (let i = clouds.length - 1; i >= 0; i--) {
      clouds[i].x -= speed * 0.25;
      if (clouds[i].x + 60 < 0) clouds.splice(i, 1);
    }
    if (Math.random() < 0.003) {
      clouds.push({ x: W + 10, y: 10 + Math.random() * (GROUND_Y * 0.35), r: 18 + Math.random() * 14 });
    }
  }

  /* ── Collisions ── */
  function checkCollisions() {
    const db = dinoBox();
    for (const o of obstacles) {
      const ob = obsBox(o);
      const m = 6;
      if (db.x + m < ob.x + ob.w - m &&
          db.x + db.w - m > ob.x + m &&
          db.y + m < ob.y + ob.h - m &&
          db.y + db.h - m > ob.y + m) return true;
    }
    return false;
  }

  function obsBox(o) {
    if (o.kind === 'bird') return { x: o.x + 4, y: o.y + 4, w: o.w - 8, h: o.h - 8 };
    return { x: o.x + 3, y: o.y - o.h + 2, w: o.w - 6, h: o.h - 2 };
  }

  /* ── Draw ── */
  function drawScene() {
    ctx.clearRect(0, 0, W, H);

    // Sky gradient
    const sky = ctx.createLinearGradient(0, 0, 0, GROUND_Y);
    sky.addColorStop(0, SKY_TOP); sky.addColorStop(1, SKY_BOT);
    ctx.fillStyle = sky;
    ctx.fillRect(0, 0, W, GROUND_Y);

    // Clouds
    clouds.forEach(c => drawCloud(c));

    // Ground
    ctx.fillStyle = GROUND_COLOR;
    ctx.fillRect(0, GROUND_Y, W, H - GROUND_Y);
    ctx.fillStyle = 'rgba(0,0,0,0.15)';
    ctx.fillRect(0, GROUND_Y, W, 3);

    // Ground texture dashes
    ctx.strokeStyle = 'rgba(255,255,255,0.18)';
    ctx.lineWidth = 1;
    ctx.setLineDash([12, 18]);
    ctx.beginPath();
    ctx.moveTo(0, GROUND_Y + 10); ctx.lineTo(W, GROUND_Y + 10);
    ctx.stroke(); ctx.setLineDash([]);

    // Obstacles
    obstacles.forEach(o => {
      if (o.kind === 'bird') drawBird(o);
      else drawCactus(o);
    });

    // Dino
    drawDino();
  }

  function drawCloud(c) {
    ctx.save();
    ctx.fillStyle = 'rgba(255,255,255,0.55)';
    ctx.beginPath();
    ctx.arc(c.x,          c.y,          c.r * 0.7, 0, Math.PI * 2);
    ctx.arc(c.x + c.r,    c.y - c.r * 0.3, c.r, 0, Math.PI * 2);
    ctx.arc(c.x + c.r * 2, c.y,         c.r * 0.7, 0, Math.PI * 2);
    ctx.fill();
    ctx.restore();
  }

  function drawDino() {
    const x = dino.x, bot = dino.y;
    ctx.fillStyle = DINO_COLOR;

    if (dino.ducking) {
      // Ducking: wide low body
      const dw = 60, dh = 28;
      rr(x + 4, bot - dh, dw - 8, dh - 2, 5);         // body
      rr(x + dw - 20, bot - dh - 10, 18, 12, 4);       // head
      ctx.beginPath(); ctx.arc(x + dw - 5, bot - dh - 4, 2.5, 0, Math.PI * 2);
      ctx.fillStyle = '#fff'; ctx.fill();
      ctx.beginPath(); ctx.arc(x + dw - 5, bot - dh - 4, 1.2, 0, Math.PI * 2);
      ctx.fillStyle = '#111'; ctx.fill();
      ctx.fillStyle = DINO_COLOR;
      // Legs (horizontal, tucked)
      rr(x + 10, bot - 10, 10, 10, 3);
      rr(x + 26, bot - 10, 10, 10, 3);
      return;
    }

    // Standing / running
    const W2 = 44, H2 = 52;

    // Tail
    ctx.beginPath();
    ctx.moveTo(x + 4, bot - 18);
    ctx.lineTo(x - 6, bot - 10);
    ctx.lineTo(x + 4, bot - 10);
    ctx.closePath(); ctx.fill();

    // Body
    rr(x + 2, bot - H2 + 22, W2 - 10, 22, 6);

    // Neck
    rr(x + W2 - 18, bot - H2 + 12, 12, 14, 4);

    // Head
    rr(x + W2 - 22, bot - H2, 24, 20, 6);

    // Snout extension
    rr(x + W2, bot - H2 + 12, 8, 7, 3);

    // Eye
    ctx.beginPath(); ctx.arc(x + W2 - 7, bot - H2 + 6, 3.5, 0, Math.PI * 2);
    ctx.fillStyle = '#fff'; ctx.fill();
    ctx.beginPath(); ctx.arc(x + W2 - 6, bot - H2 + 7, 1.8, 0, Math.PI * 2);
    ctx.fillStyle = '#111'; ctx.fill();
    ctx.fillStyle = DINO_COLOR;

    // Tiny arm
    rr(x + W2 - 14, bot - H2 + 26, 10, 5, 2);

    // Legs
    if (dino.onGround) {
      // Alternating running legs
      if (dino.legFrame === 0) {
        rr(x + 14, bot - 20, 10, 20, 3);   // front
        rr(x + 4,  bot - 12, 10, 12, 3);   // back
      } else {
        rr(x + 4,  bot - 20, 10, 20, 3);   // front
        rr(x + 14, bot - 12, 10, 12, 3);   // back
      }
    } else {
      // In air — both legs straight
      rr(x + 4,  bot - 20, 10, 20, 3);
      rr(x + 18, bot - 16, 10, 16, 3);
    }
  }

  function drawCactus(o) {
    ctx.fillStyle = CACTUS_COLOR;
    const x = o.x, bot = o.y, h = o.h;

    if (o.kind === 'cactus3') {
      // Triple: three small stems
      for (let i = 0; i < 3; i++) {
        const cx = x + i * 22;
        rr(cx + 4, bot - 46, 10, 46, 2);
        rr(cx, bot - 32, 10, 6, 2);
        rr(cx, bot - 38, 6, 14, 2);
      }
      return;
    }
    if (o.kind === 'cactus2') {
      // Double
      for (let i = 0; i < 2; i++) {
        const cx = x + i * 28;
        rr(cx + 5, bot - 60, 12, 60, 2);
        rr(cx, bot - 42, 12, 6, 2);
        rr(cx, bot - 52, 7, 16, 2);
        rr(cx + 17, bot - 36, 12, 6, 2);
        rr(cx + 17, bot - 46, 7, 16, 2);
      }
      return;
    }

    // Single cactus
    const sw = o.w === 18 ? 8 : o.w === 24 ? 10 : 12;
    const cx = x + (o.w - sw) / 2;
    rr(cx, bot - h, sw, h, 2);               // stem
    // left arm
    rr(x, bot - h * 0.55, cx - x + 2, 7, 2);
    rr(x, bot - h * 0.72, 7, h * 0.2, 2);
    // right arm
    rr(cx + sw - 2, bot - h * 0.45, o.w - cx - sw + 2, 7, 2);
    rr(x + o.w - 7,  bot - h * 0.62, 7, h * 0.18, 2);
  }

  function drawBird(o) {
    ctx.fillStyle = BIRD_COLOR;
    const x = o.x, y = o.y, w = o.w, h = o.h;

    // Body
    ctx.beginPath();
    ctx.ellipse(x + w / 2, y + h / 2, w / 2 - 2, h / 2 - 2, 0, 0, Math.PI * 2);
    ctx.fill();

    // Beak
    ctx.beginPath();
    ctx.moveTo(x + w - 4, y + h / 2 - 2);
    ctx.lineTo(x + w + 8, y + h / 2);
    ctx.lineTo(x + w - 4, y + h / 2 + 2);
    ctx.closePath(); ctx.fill();

    // Wings
    const wUp = o.wingFrame === 0;
    ctx.beginPath();
    if (wUp) {
      ctx.moveTo(x + 8, y + 4);
      ctx.lineTo(x + w / 2, y - 10);
      ctx.lineTo(x + w - 8, y + 4);
    } else {
      ctx.moveTo(x + 8, y + h - 4);
      ctx.lineTo(x + w / 2, y + h + 10);
      ctx.lineTo(x + w - 8, y + h - 4);
    }
    ctx.closePath(); ctx.fill();
  }

  /* rounded rect helper */
  function rr(x, y, w, h, r) {
    ctx.beginPath();
    ctx.roundRect(x, y, w, h, r);
    ctx.fill();
  }

  /* ── Game over / pause ── */
  function endGame() {
    gameOver = true;
    cancelAnimationFrame(raf);
    const sc = Math.floor(score);
    overlayMsg.textContent = `Game Over!\nScore: ${sc}`;
    overlay.hidden = false;
  }

  function togglePause() {
    if (gameOver) return;
    paused = !paused;
    pauseBtn.textContent = paused ? 'Resume' : 'Pause';
    if (!paused) raf = requestAnimationFrame(gameLoop);
  }

  /* ── Input ── */
  document.addEventListener('keydown', e => {
    if (!gameScreen.classList.contains('active')) return;
    if (e.key === 'ArrowUp' || e.key === ' ') { e.preventDefault(); jump(); }
    if (e.key === 'ArrowDown') { e.preventDefault(); downHeld = true; }
    if (e.key === 'p' || e.key === 'P') togglePause();
  });
  document.addEventListener('keyup', e => {
    if (e.key === 'ArrowDown') downHeld = false;
  });

  canvas.addEventListener('pointerdown', e => { e.preventDefault(); jump(); }, { passive: false });

  jumpBtn.addEventListener('pointerdown', e => { e.preventDefault(); jump(); }, { passive: false });
  duckBtn.addEventListener('pointerdown', e => { e.preventDefault(); downHeld = true; }, { passive: false });
  duckBtn.addEventListener('pointerup',   () => { downHeld = false; });
  duckBtn.addEventListener('pointerleave', () => { downHeld = false; });

  /* ── Screen transitions ── */
  startBtn.addEventListener('click', () => {
    settingsScreen.classList.remove('active');
    gameScreen.classList.add('active');
    startGame();
  });
  settingsBtn.addEventListener('click', () => {
    cancelAnimationFrame(raf);
    gameOver = true;
    gameScreen.classList.remove('active');
    settingsScreen.classList.add('active');
  });
  pauseBtn.addEventListener('click', togglePause);
  overlayBtn.addEventListener('click', startGame);

  /* ── Resize ── */
  let resizeTimer;
  window.addEventListener('resize', () => {
    clearTimeout(resizeTimer);
    resizeTimer = setTimeout(() => {
      if (gameScreen.classList.contains('active') && gameOver) initCanvas();
    }, 100);
  });
})();
</script>
