---
import GameLayout from '../../layouts/GameLayout.astro';
---
<GameLayout title="Chrome Dino">
  <div class="dino-wrapper">
    <div class="settings-screen active" id="settings-screen">
      <h1 class="game-title">Chrome Dino</h1>
      <div class="settings-form">
        <label class="field">
          <span>Difficulty</span>
          <select id="difficulty-select">
            <option value="easy">Easy</option>
            <option value="medium" selected>Medium</option>
            <option value="hard">Hard</option>
          </select>
        </label>
      </div>
      <button class="btn-primary" id="start-btn">Start Game</button>
    </div>

    <div class="game-screen" id="game-screen">
      <div class="hud">
        <span class="hud-item">Score: <strong id="score-val">0</strong></span>
        <span class="hud-item">Best: <strong id="best-val">0</strong></span>
        <span class="hud-item diff-badge" id="diff-badge"></span>
      </div>

      <div class="canvas-wrap">
        <canvas id="dino-canvas" aria-label="Chrome Dino game board"></canvas>
        <div class="overlay" id="overlay" hidden>
          <p id="overlay-msg"></p>
          <button class="btn-secondary" id="overlay-btn">Play Again</button>
        </div>
      </div>

      <div class="controls-row">
        <button class="btn-secondary" id="jump-btn">Jump</button>
        <button class="btn-secondary" id="duck-btn">Duck</button>
        <button class="btn-secondary" id="settings-btn">Settings</button>
      </div>
    </div>
  </div>
</GameLayout>

<style is:global>
  html, body { margin: 0; min-height: 100%; }
  body {
    font-family: "Segoe UI", Tahoma, Geneva, Verdana, sans-serif;
    background:
      linear-gradient(180deg, #dbeafe 0%, #f8fafc 48%, #e2e8f0 100%);
    min-height: 100dvh;
    color: #1e293b;
  }
</style>

<style>
  .dino-wrapper {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    min-height: 100dvh;
    padding: clamp(54px, 9vh, 76px) clamp(10px, 3vw, 24px) clamp(12px, 3vh, 28px);
    box-sizing: border-box;
  }
  .settings-screen,
  .game-screen {
    display: none;
    flex-direction: column;
    align-items: center;
    width: 100%;
  }
  .settings-screen.active,
  .game-screen.active { display: flex; }
  .settings-screen { gap: 20px; max-width: 400px; }
  .game-screen { gap: clamp(8px, 1.6vh, 14px); }
  .game-title {
    margin: 0;
    font-size: clamp(1.9rem, 5vw, 2.8rem);
    color: #0f172a;
  }
  .settings-form {
    display: flex;
    flex-direction: column;
    gap: 14px;
    width: 100%;
  }
  .field {
    display: flex;
    flex-direction: column;
    gap: 5px;
    font-size: 0.9rem;
    color: #475569;
    font-weight: 700;
  }
  select {
    background: #fff;
    border: 1px solid #cbd5e1;
    border-radius: 10px;
    color: #0f172a;
    padding: 10px 12px;
    font: inherit;
    cursor: pointer;
  }
  .hud {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 8px clamp(14px, 3vw, 28px);
    align-items: center;
    max-width: 100%;
    padding: 6px 16px;
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.82);
    border: 1px solid rgba(148, 163, 184, 0.35);
    color: #334155;
    box-shadow: 0 8px 22px rgba(15, 23, 42, 0.08);
    font-size: clamp(0.78rem, 2.2vw, 0.95rem);
  }
  .diff-badge {
    padding: 2px 8px;
    border-radius: 999px;
    text-transform: uppercase;
    font-size: 0.72rem;
    font-weight: 800;
    letter-spacing: 0.05em;
  }
  .diff-badge.easy { background: #dcfce7; color: #166534; }
  .diff-badge.medium { background: #fef3c7; color: #92400e; }
  .diff-badge.hard { background: #fee2e2; color: #991b1b; }
  .canvas-wrap {
    position: relative;
    width: min(100%, 900px);
    aspect-ratio: 16 / 7;
    max-height: calc(100dvh - 180px);
    border: 1px solid rgba(148, 163, 184, 0.45);
    border-radius: 14px;
    overflow: hidden;
    background: #f8fafc;
    box-shadow: 0 18px 44px rgba(15, 23, 42, 0.16);
  }
  #dino-canvas {
    display: block;
    width: 100%;
    height: 100%;
  }
  .overlay {
    position: absolute;
    inset: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 16px;
    background: rgba(248, 250, 252, 0.86);
    backdrop-filter: blur(4px);
  }
  .overlay[hidden] { display: none; }
  #overlay-msg {
    margin: 0;
    color: #0f172a;
    font-size: clamp(1rem, 4vw, 1.45rem);
    font-weight: 800;
    text-align: center;
    white-space: pre-line;
  }
  .controls-row {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 10px;
  }
  .btn-primary,
  .btn-secondary {
    border: none;
    border-radius: 12px;
    font-family: inherit;
    font-weight: 800;
    cursor: pointer;
    min-height: 44px;
    -webkit-tap-highlight-color: transparent;
    transition: transform 0.15s, background 0.15s;
  }
  .btn-primary {
    width: 100%;
    padding: 12px 28px;
    background: #2563eb;
    color: #fff;
    font-size: 1.05rem;
  }
  .btn-secondary {
    padding: 9px 20px;
    background: #fff;
    color: #1e293b;
    border: 1px solid #cbd5e1;
    box-shadow: 0 8px 18px rgba(15, 23, 42, 0.08);
  }
  .btn-primary:hover,
  .btn-secondary:hover { transform: translateY(-1px); }
  .btn-primary:hover { background: #1d4ed8; }
  .btn-secondary:hover { background: #f1f5f9; }
  @media (max-width: 520px) {
    .canvas-wrap {
      aspect-ratio: 4 / 3;
      max-height: calc(100dvh - 220px);
    }
    .controls-row { width: 100%; }
    .btn-secondary { flex: 1 1 92px; padding-inline: 12px; }
  }
  @media (orientation: landscape) and (max-height: 500px) {
    .dino-wrapper { padding: 48px 10px 8px; }
    .game-screen { gap: 6px; }
    .canvas-wrap {
      width: min(78vw, calc((100dvh - 112px) * 16 / 7));
      max-height: calc(100dvh - 112px);
    }
    .controls-row { gap: 6px; }
    .btn-secondary { min-height: 36px; padding: 6px 14px; }
  }
</style>

<script is:inline>
(function () {
  var settingsScreen = document.getElementById('settings-screen');
  var gameScreen = document.getElementById('game-screen');
  var startBtn = document.getElementById('start-btn');
  var settingsBtn = document.getElementById('settings-btn');
  var jumpBtn = document.getElementById('jump-btn');
  var duckBtn = document.getElementById('duck-btn');
  var overlay = document.getElementById('overlay');
  var overlayMsg = document.getElementById('overlay-msg');
  var overlayBtn = document.getElementById('overlay-btn');
  var scoreEl = document.getElementById('score-val');
  var bestEl = document.getElementById('best-val');
  var diffBadge = document.getElementById('diff-badge');
  var diffSel = document.getElementById('difficulty-select');
  var canvas = document.getElementById('dino-canvas');
  var ctx = canvas.getContext('2d');

  var DIFFICULTIES = {
    easy: { speed: 5.5, gravity: 0.58, gap: 1220 },
    medium: { speed: 7.0, gravity: 0.66, gap: 1000 },
    hard: { speed: 8.8, gravity: 0.76, gap: 830 }
  };
  var LS_BEST = 'chrome_dino_best';
  var LS_DIFF = 'chrome_dino_diff';
  var W = 0;
  var H = 0;
  var groundY = 0;
  var rafId = 0;
  var lastTime = 0;
  var spawnTimer = 0;
  var gameRunning = false;
  var dino;
  var obstacles;
  var clouds;
  var score;
  var best;
  var speed;
  var gravity;
  var minGap;
  var ducking = false;

  function initCanvas() {
    var wrap = canvas.parentElement;
    W = Math.max(300, wrap.clientWidth);
    H = Math.max(210, wrap.clientHeight);
    canvas.width = W;
    canvas.height = H;
    groundY = Math.round(H * 0.76);
  }

  function startGame() {
    cancelAnimationFrame(rafId);
    initCanvas();
    var key = diffSel.value;
    var cfg = DIFFICULTIES[key];
    localStorage.setItem(LS_DIFF, key);
    diffBadge.textContent = key;
    diffBadge.className = 'hud-item diff-badge ' + key;
    best = parseInt(localStorage.getItem(LS_BEST) || '0', 10);
    bestEl.textContent = best;
    score = 0;
    scoreEl.textContent = '0';
    speed = cfg.speed;
    gravity = cfg.gravity;
    minGap = cfg.gap;
    spawnTimer = 500;
    obstacles = [];
    clouds = [
      { x: W * 0.25, y: H * 0.17, s: 1.0 },
      { x: W * 0.68, y: H * 0.26, s: 0.72 }
    ];
    dino = {
      x: Math.round(W * 0.12),
      y: groundY - 50,
      w: 44,
      h: 50,
      vy: 0,
      grounded: true,
      step: 0
    };
    overlay.hidden = true;
    gameRunning = true;
    lastTime = performance.now();
    rafId = requestAnimationFrame(loop);
  }

  function loop(now) {
    if (!gameRunning) return;
    var dt = Math.min(32, now - lastTime);
    lastTime = now;
    update(dt);
    draw();
    rafId = requestAnimationFrame(loop);
  }

  function update(dt) {
    var scale = dt / 16.67;
    speed += 0.0015 * dt;
    score += dt * 0.01;
    var displayScore = Math.floor(score);
    scoreEl.textContent = displayScore;
    if (displayScore > best) {
      best = displayScore;
      bestEl.textContent = best;
      localStorage.setItem(LS_BEST, String(best));
    }

    dino.vy += gravity * scale;
    dino.y += dino.vy * scale;
    var targetH = ducking && dino.grounded ? 34 : 50;
    dino.h += (targetH - dino.h) * 0.35;
    if (dino.y + dino.h >= groundY) {
      dino.y = groundY - dino.h;
      dino.vy = 0;
      dino.grounded = true;
    }
    dino.step += dt * (dino.grounded ? 0.016 : 0.006);

    spawnTimer -= dt;
    if (spawnTimer <= 0) {
      spawnObstacle();
      spawnTimer = minGap + Math.random() * minGap * 0.55 - speed * 35;
      spawnTimer = Math.max(560, spawnTimer);
    }

    obstacles.forEach(function (obs) { obs.x -= speed * scale; });
    obstacles = obstacles.filter(function (obs) { return obs.x + obs.w > -20; });
    clouds.forEach(function (cloud) {
      cloud.x -= speed * 0.16 * scale;
      if (cloud.x < -80) {
        cloud.x = W + Math.random() * W * 0.5;
        cloud.y = H * (0.12 + Math.random() * 0.2);
      }
    });

    var hitBox = getDinoHitBox();
    for (var i = 0; i < obstacles.length; i++) {
      if (rectsOverlap(hitBox, obstacles[i])) {
        endGame();
        return;
      }
    }
  }

  function spawnObstacle() {
    var bird = score > 120 && Math.random() < 0.26;
    if (bird) {
      var high = Math.random() < 0.5;
      obstacles.push({
        type: 'bird',
        x: W + 20,
        y: high ? groundY - 86 : groundY - 58,
        w: 44,
        h: 24
      });
      return;
    }
    var tall = Math.random() < 0.42;
    obstacles.push({
      type: 'cactus',
      x: W + 20,
      y: groundY - (tall ? 54 : 42),
      w: tall ? 26 : 22,
      h: tall ? 54 : 42
    });
  }

  function jump() {
    if (!gameRunning) return;
    if (dino.grounded) {
      dino.vy = -Math.max(11.5, H * 0.044);
      dino.grounded = false;
    }
  }

  function setDucking(value) {
    ducking = value;
  }

  function endGame() {
    gameRunning = false;
    cancelAnimationFrame(rafId);
    draw();
    overlayMsg.textContent = 'Game Over\nScore: ' + Math.floor(score);
    overlay.hidden = false;
  }

  function draw() {
    ctx.clearRect(0, 0, W, H);
    drawSky();
    drawGround();
    clouds.forEach(drawCloud);
    obstacles.forEach(drawObstacle);
    drawDino();
  }

  function drawSky() {
    var grad = ctx.createLinearGradient(0, 0, 0, H);
    grad.addColorStop(0, '#eff6ff');
    grad.addColorStop(1, '#f8fafc');
    ctx.fillStyle = grad;
    ctx.fillRect(0, 0, W, H);
    ctx.fillStyle = '#facc15';
    ctx.beginPath();
    ctx.arc(W - 52, 44, 18, 0, Math.PI * 2);
    ctx.fill();
  }

  function drawGround() {
    ctx.strokeStyle = '#64748b';
    ctx.lineWidth = 3;
    ctx.beginPath();
    ctx.moveTo(0, groundY + 1);
    ctx.lineTo(W, groundY + 1);
    ctx.stroke();
    ctx.fillStyle = '#94a3b8';
    for (var x = -((score * speed) % 90); x < W; x += 90) {
      ctx.fillRect(x + 16, groundY + 16, 34, 3);
      ctx.fillRect(x + 62, groundY + 28, 18, 3);
    }
  }

  function drawCloud(cloud) {
    ctx.fillStyle = 'rgba(148, 163, 184, 0.58)';
    var x = cloud.x;
    var y = cloud.y;
    var s = cloud.s;
    ctx.beginPath();
    ctx.arc(x, y, 12 * s, 0, Math.PI * 2);
    ctx.arc(x + 14 * s, y - 8 * s, 15 * s, 0, Math.PI * 2);
    ctx.arc(x + 31 * s, y, 12 * s, 0, Math.PI * 2);
    ctx.fill();
  }

  function drawDino() {
    var x = dino.x;
    var y = dino.y;
    var duck = ducking && dino.grounded;
    ctx.fillStyle = '#334155';
    if (duck) {
      roundedRect(x, y + 10, 58, 28, 5);
      roundedRect(x + 36, y, 25, 20, 4);
      ctx.fillRect(x + 10, y + 33, 8, 13);
      ctx.fillRect(x + 39, y + 33, 8, 13);
    } else {
      roundedRect(x, y + 11, 32, 35, 5);
      roundedRect(x + 20, y, 25, 23, 4);
      ctx.fillRect(x + 5, y + 42, 8, 14);
      ctx.fillRect(x + 25, y + 42, 8, 14);
      ctx.fillRect(x - 8, y + 24, 14, 6);
    }
    ctx.fillStyle = '#f8fafc';
    ctx.fillRect(x + (duck ? 51 : 37), y + (duck ? 7 : 7), 4, 4);
    ctx.fillStyle = '#334155';
    var legLift = Math.sin(dino.step) > 0 ? 0 : 5;
    if (dino.grounded) {
      ctx.fillRect(x + 5, groundY - 4 - legLift, 12, 4);
      ctx.fillRect(x + 25, groundY - 9 + legLift, 12, 4);
    }
  }

  function drawObstacle(obs) {
    if (obs.type === 'bird') {
      ctx.fillStyle = '#475569';
      roundedRect(obs.x + 10, obs.y + 6, 24, 14, 5);
      var flap = Math.sin(score * 0.25) > 0 ? -8 : 8;
      ctx.beginPath();
      ctx.moveTo(obs.x + 20, obs.y + 12);
      ctx.lineTo(obs.x, obs.y + 12 + flap);
      ctx.lineTo(obs.x + 20, obs.y + 18);
      ctx.moveTo(obs.x + 30, obs.y + 12);
      ctx.lineTo(obs.x + 48, obs.y + 12 + flap);
      ctx.lineTo(obs.x + 30, obs.y + 18);
      ctx.fill();
      return;
    }
    ctx.fillStyle = '#16a34a';
    roundedRect(obs.x + obs.w * 0.35, obs.y, obs.w * 0.3, obs.h, 4);
    roundedRect(obs.x, obs.y + obs.h * 0.34, obs.w * 0.42, 8, 4);
    roundedRect(obs.x + obs.w * 0.58, obs.y + obs.h * 0.52, obs.w * 0.42, 8, 4);
  }

  function roundedRect(x, y, w, h, r) {
    ctx.beginPath();
    ctx.roundRect(x, y, w, h, r);
    ctx.fill();
  }

  function getDinoHitBox() {
    var duck = ducking && dino.grounded;
    return {
      x: dino.x + 4,
      y: dino.y + (duck ? 12 : 4),
      w: duck ? 52 : 38,
      h: duck ? 24 : 44
    };
  }

  function rectsOverlap(a, b) {
    return a.x < b.x + b.w && a.x + a.w > b.x && a.y < b.y + b.h && a.y + a.h > b.y;
  }

  startBtn.addEventListener('click', function () {
    settingsScreen.classList.remove('active');
    gameScreen.classList.add('active');
    startGame();
  });
  settingsBtn.addEventListener('click', function () {
    gameRunning = false;
    cancelAnimationFrame(rafId);
    gameScreen.classList.remove('active');
    settingsScreen.classList.add('active');
  });
  overlayBtn.addEventListener('click', startGame);
  jumpBtn.addEventListener('click', jump);
  duckBtn.addEventListener('pointerdown', function (e) { e.preventDefault(); setDucking(true); });
  duckBtn.addEventListener('pointerup', function () { setDucking(false); });
  duckBtn.addEventListener('pointerleave', function () { setDucking(false); });
  canvas.addEventListener('pointerdown', function () { jump(); });
  document.addEventListener('keydown', function (e) {
    if (!gameScreen.classList.contains('active')) return;
    if (e.code === 'Space' || e.key === 'ArrowUp' || e.key === 'w' || e.key === 'W') {
      e.preventDefault();
      jump();
    }
    if (e.key === 'ArrowDown' || e.key === 's' || e.key === 'S') {
      e.preventDefault();
      setDucking(true);
    }
  });
  document.addEventListener('keyup', function (e) {
    if (e.key === 'ArrowDown' || e.key === 's' || e.key === 'S') {
      setDucking(false);
    }
  });
  var resizeTimer;
  window.addEventListener('resize', function () {
    clearTimeout(resizeTimer);
    resizeTimer = setTimeout(function () {
      if (gameScreen.classList.contains('active')) {
        initCanvas();
        draw();
      }
    }, 120);
  });
  var savedDiff = localStorage.getItem(LS_DIFF);
  if (savedDiff && DIFFICULTIES[savedDiff]) diffSel.value = savedDiff;
})();
</script>
