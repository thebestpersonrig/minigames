---
import GameLayout from '../../layouts/GameLayout.astro';
---
<GameLayout title="Subway Surfers">
  <div class="ss-wrap">

    <!-- ── Settings ── -->
    <div class="settings-screen active" id="settings-screen">
      <h1 class="game-title">Subway Surfers</h1>
      <p class="tagline">Switch lanes to dodge trains.<br/>Jump barriers · Slide under beams · Collect coins!</p>
      <div class="settings-form">
        <label class="field">
          <span>Difficulty</span>
          <select id="diff-sel">
            <option value="easy">Easy</option>
            <option value="medium" selected>Medium</option>
            <option value="hard">Hard</option>
          </select>
        </label>
      </div>
      <button class="btn-primary" id="start-btn">Start Game</button>
    </div>

    <!-- ── Game ── -->
    <div class="game-screen" id="game-screen">
      <div class="hud">
        <span class="hud-item"><strong id="score-val">0</strong>m</span>
        <span class="hud-item">Coins <strong id="coin-val">0</strong></span>
        <span class="hud-item">Best <strong id="best-val">0</strong>m</span>
        <span class="hud-item diff-badge" id="diff-badge"></span>
      </div>
      <div class="canvas-wrap">
        <canvas id="ss-canvas" aria-label="Subway Surfers game"></canvas>
        <div class="overlay" id="overlay" hidden>
          <p id="overlay-msg"></p>
          <button class="btn-secondary" id="overlay-btn">Play Again</button>
        </div>
      </div>
      <div class="controls-row">
        <button class="btn-secondary" id="settings-btn">Settings</button>
      </div>
      <p class="hint" id="hint-text"></p>
    </div>

  </div>
</GameLayout>

<style is:global>
  html, body { margin: 0; min-height: 100%; }
  body {
    font-family: "Segoe UI", Tahoma, Geneva, Verdana, sans-serif;
    background:
      radial-gradient(circle at top left,  rgba(255,255,255,0.12), transparent 28%),
      radial-gradient(circle at bottom right, rgba(255,255,255,0.08), transparent 22%),
      linear-gradient(135deg, #1a0533, #2d0856);
    min-height: 100dvh;
    color: #fff;
  }
</style>

<style>
  .ss-wrap {
    display: flex; flex-direction: column; align-items: center; justify-content: center;
    min-height: 100dvh;
    padding: clamp(50px, 8vh, 76px) clamp(10px, 3vw, 24px) clamp(12px, 3vh, 28px);
    box-sizing: border-box;
  }

  /* Settings */
  .settings-screen {
    display: none; flex-direction: column; align-items: center;
    gap: 20px; width: 100%; max-width: 400px; text-align: center;
  }
  .settings-screen.active { display: flex; }
  .game-title {
    margin: 0; font-size: clamp(1.8rem, 5vw, 2.6rem);
    font-weight: 900; letter-spacing: 0.04em;
    text-shadow: 0 4px 14px rgba(0,0,0,0.35); color: #ce93d8;
  }
  .tagline { margin: 0; font-size: 0.95rem; color: rgba(255,255,255,0.72); line-height: 1.55; }
  .settings-form { display: flex; flex-direction: column; gap: 14px; width: 100%; }
  .field { display: flex; flex-direction: column; gap: 4px; font-size: 0.9rem; color: rgba(255,255,255,0.8); text-align: left; }
  select {
    background: rgba(255,255,255,0.12); border: 1px solid rgba(255,255,255,0.25);
    border-radius: 10px; color: #fff; padding: 10px 12px;
    font-size: 1rem; font-family: inherit; cursor: pointer;
    appearance: none; -webkit-appearance: none;
  }
  select option { background: #1a0533; color: #fff; }

  /* Game screen */
  .game-screen {
    display: none; flex-direction: column; align-items: center;
    gap: clamp(6px, 1.4vh, 12px); width: 100%;
  }
  .game-screen.active { display: flex; }

  /* HUD */
  .hud {
    display: flex; gap: clamp(14px, 3vw, 28px); align-items: center;
    font-size: clamp(0.8rem, 2.4vw, 0.95rem);
    background: rgba(0,0,0,0.28); padding: 5px 18px; border-radius: 999px;
  }
  .diff-badge {
    font-size: 0.72rem; font-weight: 700; letter-spacing: 0.05em;
    padding: 2px 8px; border-radius: 999px; text-transform: uppercase;
  }
  .diff-badge.easy   { background: #22c55e33; color: #4ade80; }
  .diff-badge.medium { background: #a855f733; color: #d8b4fe; }
  .diff-badge.hard   { background: #ef444433; color: #f87171; }

  /* Canvas */
  .canvas-wrap {
    position: relative;
    width: min(min(100vw - 20px, 100dvh - 148px), 520px);
    aspect-ratio: 1;
    border-radius: 14px; overflow: hidden;
    box-shadow: 0 10px 40px rgba(0,0,0,0.5);
  }
  @media (pointer: coarse) {
    .canvas-wrap { width: min(100vw - 20px, calc(100dvh - clamp(200px, 36vh, 260px))); }
  }
  #ss-canvas { display: block; width: 100%; height: 100%; }

  /* Overlay */
  .overlay {
    position: absolute; inset: 0; background: rgba(0,0,0,0.68);
    display: flex; flex-direction: column; align-items: center;
    justify-content: center; gap: 16px; border-radius: 14px;
  }
  .overlay[hidden] { display: none; }
  #overlay-msg {
    margin: 0; font-size: clamp(1rem, 4vw, 1.4rem);
    font-weight: 700; text-align: center; padding: 0 16px; white-space: pre-line;
  }

  .controls-row { display: flex; gap: 12px; }
  .hint { margin: 0; font-size: 0.78rem; color: rgba(255,255,255,0.38); letter-spacing: 0.04em; text-align: center; }

  /* Buttons */
  .btn-primary, .btn-secondary {
    border: none; border-radius: 12px; font-family: inherit; font-weight: 600;
    cursor: pointer; transition: transform 0.15s, background 0.15s;
    -webkit-tap-highlight-color: transparent; min-height: 44px;
  }
  .btn-primary { background: #ce93d8; color: #1a0533; font-size: 1.05rem; padding: 12px 28px; width: 100%; }
  .btn-primary:hover { transform: translateY(-2px); background: #ba68c8; }
  .btn-secondary {
    background: rgba(255,255,255,0.14); color: #fff;
    font-size: 0.9rem; padding: 10px 22px; border: 1px solid rgba(255,255,255,0.2);
  }
  .btn-secondary:hover { background: rgba(255,255,255,0.24); }

  @media (orientation: landscape) and (max-height: 500px) {
    .ss-wrap { flex-direction: row; padding: 8px 12px 8px clamp(44px,10vw,60px); gap: 12px; }
    .game-screen { flex-direction: row; align-items: center; gap: 12px; }
    .canvas-wrap { width: min(calc(100dvh - 60px), 340px); }
    .hud { flex-direction: column; gap: 6px; padding: 8px 12px; }
  }
</style>

<script is:inline>
(function () {
  /* ── DOM ── */
  const settingsScreen = document.getElementById('settings-screen');
  const gameScreen     = document.getElementById('game-screen');
  const startBtn       = document.getElementById('start-btn');
  const settingsBtn    = document.getElementById('settings-btn');
  const overlay        = document.getElementById('overlay');
  const overlayMsg     = document.getElementById('overlay-msg');
  const overlayBtn     = document.getElementById('overlay-btn');
  const scoreEl        = document.getElementById('score-val');
  const coinEl         = document.getElementById('coin-val');
  const bestEl         = document.getElementById('best-val');
  const diffBadge      = document.getElementById('diff-badge');
  const hintEl         = document.getElementById('hint-text');
  const canvas         = document.getElementById('ss-canvas');
  const ctx            = canvas.getContext('2d');
  const diffSel        = document.getElementById('diff-sel');

  const IS_PHONE = window.matchMedia('(pointer: coarse)').matches;

  hintEl.textContent = IS_PHONE
    ? 'Swipe up/down to switch lanes · Tap to jump'
    : '↑ ↓ switch lanes · Space jump · Shift slide';

  /* ── Config ── */
  const DIFFICULTIES = {
    easy:   { baseSpeed: 3.0, spawnInt: 110, accel: 0.0008, barrierBeamChance: 0.12 },
    medium: { baseSpeed: 4.6, spawnInt: 85,  accel: 0.0014, barrierBeamChance: 0.28 },
    hard:   { baseSpeed: 6.8, spawnInt: 65,  accel: 0.0024, barrierBeamChance: 0.50 },
  };

  const RAIL_COUNT  = 3;
  const JUMP_DUR    = 30;   // frames for a jump cycle
  const SLIDE_DUR   = 38;   // frames for a slide
  const SWITCH_DUR  = 10;   // frames for lane-switch transition
  const MIN_SPAWN   = 50;   // minimum frames between spawns

  /* ── Layout (set in initCanvas) ── */
  let W, H, SC;
  let RAIL_Y;    // [y0,y1,y2] pixel center of each rail
  let RAIL_H;    // height of one rail zone (px)
  let CHAR_X, CHAR_W, CHAR_H;

  /* ── State ── */
  let player, obstacles, coins, distance, coinCount, best = 0;
  let speed, frameCount, spawnTimer, gameRunning, started, diff, animId;
  let cityOffset;

  /* ── Canvas init ── */
  function initCanvas() {
    const sz = canvas.parentElement.clientWidth;
    canvas.width = canvas.height = sz;
    W = H = sz; SC = sz / 400;
    RAIL_Y = [H * 0.27, H * 0.50, H * 0.73];
    RAIL_H  = H * 0.17;
    CHAR_X  = W * 0.16;
    CHAR_W  = W * 0.055;
    CHAR_H  = H * 0.105;
  }

  /* ── Player position helpers ── */
  function playerY() {
    if (!player.switching) return RAIL_Y[player.rail];
    const from = RAIL_Y[player.rail];
    const to   = RAIL_Y[player.targetRail];
    const t    = Math.min(1, player.switchT / SWITCH_DUR);
    return from + (to - from) * (t < 0.5 ? 2 * t * t : -1 + (4 - 2 * t) * t);
  }

  function jumpOffsetY() {
    if (!player.jumping) return 0;
    const t = player.jumpT / JUMP_DUR;
    return -RAIL_H * 1.0 * 4 * t * (1 - t); // parabola peak = -RAIL_H
  }

  function currentRail() {
    if (!player.switching) return player.rail;
    return player.switchT >= SWITCH_DUR / 2 ? player.targetRail : player.rail;
  }

  /* ── Spawn ── */
  function spawnObstacle() {
    if (Math.random() < 0.32) { spawnCoinRun(); return; }

    const rail = Math.floor(Math.random() * RAIL_COUNT);
    const roll = Math.random();
    let type;
    // On phones, no beams (no slide gesture)
    const chance = diff.barrierBeamChance;
    if (!IS_PHONE && roll < chance * 0.45) type = 'beam';
    else if (roll < chance)                type = 'barrier';
    else                                   type = 'train';

    const w = type === 'train' ? W * 0.20 : W * 0.068;
    obstacles.push({ type, rail, x: W + 4, w });
  }

  function spawnCoinRun() {
    const rail  = Math.floor(Math.random() * RAIL_COUNT);
    const count = 3 + Math.floor(Math.random() * 5);
    const gap   = W * 0.08;
    for (let i = 0; i < count; i++) {
      coins.push({ rail, x: W + i * gap, r: W * 0.022, collected: false });
    }
  }

  /* ── Player actions ── */
  function switchRail(dir) {
    if (!started) started = true;
    const cur  = player.switching ? player.targetRail : player.rail;
    const next = cur + dir;
    if (next < 0 || next >= RAIL_COUNT) return;
    if (player.switching) player.rail = player.targetRail; // snap current
    player.targetRail = next;
    player.switchT    = 0;
    player.switching  = true;
  }

  function doJump() {
    if (!started) started = true;
    player.jumping = true;
    player.jumpT   = 0;
  }

  function doSlide() {
    if (!started) started = true;
    if (!player.sliding) { player.sliding = true; player.slideT = 0; }
  }

  /* ── Input ── */
  document.addEventListener('keydown', e => {
    if (!gameScreen.classList.contains('active')) return;
    if (e.key === 'ArrowUp'   || e.key === 'w' || e.key === 'W') { e.preventDefault(); switchRail(-1); }
    if (e.key === 'ArrowDown' || e.key === 's' || e.key === 'S') { e.preventDefault(); switchRail(1);  }
    if (e.key === ' ')       { e.preventDefault(); doJump();  }
    if (e.key === 'Shift')   { e.preventDefault(); doSlide(); }
  });

  let tx0 = null, ty0 = null;
  canvas.addEventListener('touchstart', e => {
    tx0 = e.touches[0].clientX; ty0 = e.touches[0].clientY;
  }, { passive: true });
  canvas.addEventListener('touchend', e => {
    if (tx0 == null) return;
    const dx = e.changedTouches[0].clientX - tx0;
    const dy = e.changedTouches[0].clientY - ty0;
    tx0 = ty0 = null;
    if (Math.abs(dx) < 18 && Math.abs(dy) < 18) { doJump(); return; }
    if (Math.abs(dy) >= Math.abs(dx)) {
      if (dy < 0) switchRail(-1);
      else        switchRail(1);
    }
  }, { passive: true });

  /* ── Game lifecycle ── */
  function startGame() {
    cancelAnimationFrame(animId);
    initCanvas();

    const key = diffSel.value;
    diff = { ...DIFFICULTIES[key] };
    if (IS_PHONE) {
      diff.baseSpeed *= 0.75;
      diff.spawnInt   = Math.round(diff.spawnInt * 1.25);
    }
    diffBadge.textContent = key;
    diffBadge.className   = `hud-item diff-badge ${key}`;

    player = {
      rail: 1, targetRail: 1, switching: false, switchT: 0,
      jumping: false, jumpT: 0,
      sliding: false, slideT: 0,
    };
    obstacles = []; coins = [];
    distance = 0; coinCount = 0;
    frameCount = 0; spawnTimer = 70;
    started = false; gameRunning = true;
    speed = diff.baseSpeed;
    cityOffset = 0;

    overlay.hidden = true;
    scoreEl.textContent = '0';
    coinEl.textContent  = '0';

    animId = requestAnimationFrame(gameLoop);
  }

  function gameLoop() {
    if (!gameRunning) return;
    animId = requestAnimationFrame(gameLoop);
    if (started) {
      frameCount++;
      update();
      if (!gameRunning) { draw(); return; }
    }
    draw();
    if (!started) drawStartPrompt();
  }

  /* ── Update ── */
  function update() {
    speed = diff.baseSpeed + frameCount * diff.accel;
    const sp = speed * SC;

    // Player timers
    if (player.switching) {
      if (++player.switchT >= SWITCH_DUR) {
        player.rail = player.targetRail;
        player.switching = false; player.switchT = 0;
      }
    }
    if (player.jumping && ++player.jumpT >= JUMP_DUR) {
      player.jumping = false; player.jumpT = 0;
    }
    if (player.sliding && ++player.slideT >= SLIDE_DUR) {
      player.sliding = false; player.slideT = 0;
    }

    // Move world
    for (const o of obstacles) o.x -= sp;
    for (const c of coins)     c.x -= sp;
    cityOffset += sp * 0.38;

    // Spawn
    if (--spawnTimer <= 0) {
      spawnObstacle();
      spawnTimer = Math.max(MIN_SPAWN, Math.round(diff.spawnInt - frameCount / 100));
    }

    // Collision
    const cRail = currentRail();
    const cL    = CHAR_X - CHAR_W * 0.42;
    const cR    = CHAR_X + CHAR_W * 0.42;

    for (const obs of obstacles) {
      if (obs.rail !== cRail) continue;
      if (cR <= obs.x || cL >= obs.x + obs.w) continue;
      if (obs.type === 'train')                        { endGame(); return; }
      if (obs.type === 'barrier' && !player.jumping)   { endGame(); return; }
      if (obs.type === 'beam'    && !player.sliding)   { endGame(); return; }
    }

    // Coin pickup
    for (const c of coins) {
      if (c.collected || c.rail !== cRail) continue;
      if (Math.abs(c.x - CHAR_X) < CHAR_W * 1.2) {
        c.collected = true;
        coinCount++;
        coinEl.textContent = coinCount;
      }
    }

    // Score
    distance += speed * SC / (W * 0.45);
    const dist = Math.floor(distance);
    scoreEl.textContent = dist;
    if (dist > best) { best = dist; bestEl.textContent = best; }

    // Cleanup
    obstacles = obstacles.filter(o => o.x + o.w > -10);
    coins      = coins.filter(c => c.x > -20 && !c.collected);
  }

  function endGame() {
    gameRunning = false;
    overlayMsg.textContent =
      `Game Over!\nDistance: ${Math.floor(distance)}m\nCoins: ${coinCount}`;
    overlay.hidden = false;
  }

  /* ══════════════════════════════════════════════════════════
     Drawing
  ══════════════════════════════════════════════════════════ */
  function draw() {
    // Sky
    const sky = ctx.createLinearGradient(0, 0, 0, H * 0.42);
    sky.addColorStop(0, '#0d0720');
    sky.addColorStop(1, '#1a0d40');
    ctx.fillStyle = sky; ctx.fillRect(0, 0, W, H * 0.42);

    drawCity();

    // Ground strip
    const gGrad = ctx.createLinearGradient(0, H * 0.85, 0, H);
    gGrad.addColorStop(0, '#1a1028'); gGrad.addColorStop(1, '#0d0820');
    ctx.fillStyle = gGrad; ctx.fillRect(0, H * 0.85, W, H * 0.15);

    drawRails();

    for (const c of coins) if (!c.collected) drawCoin(c);
    for (const o of obstacles) drawObstacle(o);
    drawCharacter();
  }

  /* ── Pseudo-random helper (deterministic by seed) ── */
  function prand(seed) {
    const s = ((seed * 1664525 + 1013904223) & 0x7fffffff);
    return (s % 100) / 100;
  }

  /* ── City skyline ── */
  function drawCity() {
    const horizY = H * 0.42;
    // [relX, width, height, colorIdx]
    const defs = [
      [0.00, 0.11, 0.32, 0], [0.09, 0.08, 0.19, 1], [0.16, 0.13, 0.41, 2],
      [0.28, 0.07, 0.24, 0], [0.34, 0.12, 0.34, 1], [0.45, 0.09, 0.28, 2],
      [0.53, 0.14, 0.43, 0], [0.66, 0.08, 0.21, 1], [0.73, 0.11, 0.36, 2],
      [0.83, 0.09, 0.27, 0], [0.91, 0.12, 0.31, 1],
    ];
    const cols = ['#0e0928', '#110b32', '#0a0620'];
    const off  = cityOffset % W;

    for (const [rx, rw, rh, ci] of defs) {
      for (let wrap = -1; wrap <= 1; wrap++) {
        const bx = rx * W - off + wrap * W;
        const bw = rw * W;
        if (bx + bw < 0 || bx > W) continue;
        const bh = rh * H;
        const by = horizY - bh;

        ctx.fillStyle = cols[ci];
        ctx.fillRect(bx, by, bw, bh);

        // Windows (deterministic per pixel tile)
        const ww = 3 * SC, wh = 3 * SC, hg = 7 * SC, vg = 8 * SC;
        ctx.fillStyle = 'rgba(255,220,80,0.52)';
        for (let wy = by + 6 * SC; wy + wh < horizY - 3 * SC; wy += vg) {
          for (let wx = bx + 4 * SC; wx + ww < bx + bw - 3 * SC; wx += hg) {
            const seed = (Math.round(wx / ww) * 37 + Math.round(wy / wh) * 131) | 0;
            if (prand(seed) < 0.60) ctx.fillRect(wx, wy, ww, wh);
          }
        }
      }
    }

    // Neon horizon glow
    const glow = ctx.createLinearGradient(0, horizY - 18 * SC, 0, horizY + 18 * SC);
    glow.addColorStop(0, 'rgba(180,0,255,0)');
    glow.addColorStop(0.5, 'rgba(160,0,230,0.20)');
    glow.addColorStop(1, 'rgba(0,0,0,0)');
    ctx.fillStyle = glow; ctx.fillRect(0, horizY - 18 * SC, W, 36 * SC);
  }

  /* ── Rails ── */
  function drawRails() {
    const tieSpacing = 22 * SC;
    const tieOff     = (cityOffset * 1.6) % tieSpacing;

    for (let i = 0; i < RAIL_COUNT; i++) {
      const cy  = RAIL_Y[i];
      const top = cy - RAIL_H * 0.5;
      const bot = cy + RAIL_H * 0.5;

      // Zone background
      const zg = ctx.createLinearGradient(0, top, 0, bot);
      zg.addColorStop(0, 'rgba(30,15,60,0.85)');
      zg.addColorStop(0.5, 'rgba(40,20,80,0.92)');
      zg.addColorStop(1, 'rgba(30,15,60,0.85)');
      ctx.fillStyle = zg; ctx.fillRect(0, top, W, RAIL_H);

      // Divider
      if (i < RAIL_COUNT - 1) {
        ctx.strokeStyle = 'rgba(180,100,255,0.18)';
        ctx.lineWidth = 1;
        ctx.beginPath(); ctx.moveTo(0, bot); ctx.lineTo(W, bot); ctx.stroke();
      }

      // Two rails lines
      const r1 = cy - RAIL_H * 0.28;
      const r2 = cy + RAIL_H * 0.28;
      ctx.strokeStyle = 'rgba(200,160,255,0.55)';
      ctx.lineWidth = 2 * SC;
      ctx.beginPath(); ctx.moveTo(0, r1); ctx.lineTo(W, r1); ctx.stroke();
      ctx.beginPath(); ctx.moveTo(0, r2); ctx.lineTo(W, r2); ctx.stroke();

      // Cross-ties
      ctx.strokeStyle = 'rgba(100,70,50,0.55)';
      ctx.lineWidth = 3 * SC;
      for (let tx = -tieOff; tx < W + tieSpacing; tx += tieSpacing) {
        ctx.beginPath();
        ctx.moveTo(tx, r1 - 2 * SC); ctx.lineTo(tx, r2 + 2 * SC);
        ctx.stroke();
      }
    }
  }

  /* ── Obstacles ── */
  function drawObstacle(obs) {
    const cy = RAIL_Y[obs.rail];
    let ot, ob; // top, bottom

    if (obs.type === 'train') {
      ot = cy - RAIL_H * 0.46; ob = cy + RAIL_H * 0.46;
    } else if (obs.type === 'barrier') {
      ot = cy + RAIL_H * 0.10; ob = cy + RAIL_H * 0.46;
    } else { // beam
      ot = cy - RAIL_H * 0.46; ob = cy - RAIL_H * 0.08;
    }
    const ow = obs.w, oh = ob - ot;

    if (obs.type === 'train') {
      const trainCols = ['#e53935', '#fb8c00', '#43a047'];
      const col = trainCols[obs.rail];
      const rr  = 5 * SC;

      ctx.fillStyle = col;
      ctx.beginPath(); ctx.roundRect(obs.x, ot, ow, oh, rr); ctx.fill();

      // Top/bottom darker bands
      ctx.fillStyle = 'rgba(0,0,0,0.30)';
      ctx.fillRect(obs.x, ot, ow, oh * 0.16);
      ctx.fillRect(obs.x, ob - oh * 0.16, ow, oh * 0.16);

      // Windows
      ctx.fillStyle = 'rgba(180,230,255,0.65)';
      const wh2 = oh * 0.28, wy2 = ot + oh * 0.26, ww2 = ow * 0.18;
      for (let wi = 0; wi < 3; wi++) {
        const wx2 = obs.x + ow * (0.10 + wi * 0.28);
        ctx.beginPath(); ctx.roundRect(wx2, wy2, ww2, wh2, 2 * SC); ctx.fill();
      }
      // Neon trim
      ctx.strokeStyle = 'rgba(255,255,255,0.25)'; ctx.lineWidth = 1.5;
      ctx.beginPath(); ctx.roundRect(obs.x, ot, ow, oh, rr); ctx.stroke();

    } else if (obs.type === 'barrier') {
      ctx.fillStyle = '#f9a825';
      ctx.beginPath(); ctx.roundRect(obs.x, ot, ow, oh, 4 * SC); ctx.fill();
      // Black hazard stripes
      ctx.fillStyle = 'rgba(0,0,0,0.52)';
      const sh = oh / 5;
      for (let si = 1; si < 5; si += 2) ctx.fillRect(obs.x, ot + si * sh, ow, sh);
      ctx.strokeStyle = '#555'; ctx.lineWidth = 1.5;
      ctx.beginPath(); ctx.roundRect(obs.x, ot, ow, oh, 4 * SC); ctx.stroke();

    } else { // beam
      ctx.fillStyle = '#b71c1c';
      ctx.beginPath(); ctx.roundRect(obs.x, ot, ow, oh, 4 * SC); ctx.fill();
      ctx.fillStyle = 'rgba(255,230,0,0.45)';
      const sw = ow / 6;
      for (let si = 0; si < 6; si += 2) ctx.fillRect(obs.x + si * sw, ot, sw, oh);
      ctx.strokeStyle = '#7f0000'; ctx.lineWidth = 1.5;
      ctx.beginPath(); ctx.roundRect(obs.x, ot, ow, oh, 4 * SC); ctx.stroke();
    }
  }

  /* ── Coins ── */
  function drawCoin(c) {
    const pulse = 1 + 0.08 * Math.sin(frameCount * 0.15 + c.x * 0.05);
    ctx.save();
    ctx.translate(c.x, RAIL_Y[c.rail]);
    ctx.scale(pulse, pulse);
    ctx.beginPath(); ctx.arc(0, 0, c.r, 0, Math.PI * 2);
    ctx.fillStyle = '#ffd600'; ctx.fill();
    ctx.strokeStyle = '#f9a825'; ctx.lineWidth = 1.5; ctx.stroke();
    ctx.fillStyle = '#bf360c';
    ctx.textAlign = 'center'; ctx.textBaseline = 'middle';
    ctx.font = `bold ${Math.round(c.r * 1.1)}px sans-serif`;
    ctx.fillText('$', 0, 0.5);
    ctx.restore();
  }

  /* ── Character ── */
  function drawCharacter() {
    const cy    = playerY() + jumpOffsetY();
    const slide = player.sliding && player.slideT < SLIDE_DUR;
    const h     = slide ? CHAR_H * 0.46 : CHAR_H;
    const slideYShift = slide ? CHAR_H * 0.27 : 0;
    const phase = frameCount * 0.28;

    ctx.save();
    ctx.translate(CHAR_X, cy + slideYShift);

    // Ground shadow
    ctx.fillStyle = 'rgba(0,0,0,0.22)';
    ctx.beginPath();
    ctx.ellipse(0, CHAR_H * 0.5 - slideYShift + jumpOffsetY() * (-0.1), CHAR_W * 0.55, 3.5 * SC, 0, 0, Math.PI * 2);
    ctx.fill();

    if (slide) {
      // Slide pose: flat oval body + forward-stretched head
      ctx.fillStyle = '#e53935';
      ctx.beginPath(); ctx.ellipse(0, 0, CHAR_W * 0.95, h * 0.5, 0, 0, Math.PI * 2); ctx.fill();
      ctx.fillStyle = '#ffcc80';
      ctx.beginPath(); ctx.arc(CHAR_W * 0.7, -h * 0.1, CHAR_W * 0.37, 0, Math.PI * 2); ctx.fill();
      ctx.fillStyle = '#111';
      ctx.beginPath(); ctx.arc(CHAR_W * 0.85, -h * 0.14, 2 * SC, 0, Math.PI * 2); ctx.fill();
    } else {
      const legSwing = Math.sin(phase) * h * 0.28;
      const armSwing = Math.sin(phase) * h * 0.22;

      // Legs
      ctx.strokeStyle = '#1565c0'; ctx.lineWidth = 3.5 * SC; ctx.lineCap = 'round';
      ctx.beginPath(); ctx.moveTo(-CHAR_W * 0.14, h * 0.22);
      ctx.lineTo(-CHAR_W * 0.14 - legSwing * 0.25, h * 0.50); ctx.stroke();
      ctx.beginPath(); ctx.moveTo(CHAR_W * 0.14, h * 0.22);
      ctx.lineTo(CHAR_W * 0.14 + legSwing * 0.25, h * 0.50); ctx.stroke();

      // Body
      ctx.fillStyle = '#e53935';
      ctx.beginPath(); ctx.roundRect(-CHAR_W * 0.38, -h * 0.30, CHAR_W * 0.76, h * 0.52, 4 * SC); ctx.fill();

      // Arms
      ctx.strokeStyle = '#ffcc80'; ctx.lineWidth = 3 * SC;
      ctx.beginPath(); ctx.moveTo(-CHAR_W * 0.38, -h * 0.18);
      ctx.lineTo(-CHAR_W * 0.66, -h * 0.06 + armSwing * 0.18); ctx.stroke();
      ctx.beginPath(); ctx.moveTo(CHAR_W * 0.38, -h * 0.18);
      ctx.lineTo(CHAR_W * 0.66, -h * 0.06 - armSwing * 0.18); ctx.stroke();

      // Head
      ctx.fillStyle = '#ffcc80';
      ctx.beginPath(); ctx.arc(0, -h * 0.44, CHAR_W * 0.40, 0, Math.PI * 2); ctx.fill();
      // Eye
      ctx.fillStyle = '#111';
      ctx.beginPath(); ctx.arc(CHAR_W * 0.14, -h * 0.46, 2 * SC, 0, Math.PI * 2); ctx.fill();
    }

    // Jump glow
    if (player.jumping) {
      const t = player.jumpT / JUMP_DUR;
      const a = Math.sin(t * Math.PI) * 0.32;
      ctx.fillStyle = `rgba(255,255,120,${a})`;
      ctx.beginPath(); ctx.arc(0, 0, CHAR_W * 1.3, 0, Math.PI * 2); ctx.fill();
    }

    ctx.restore();
  }

  function drawStartPrompt() {
    ctx.fillStyle = 'rgba(0,0,0,0.48)';
    ctx.fillRect(0, 0, W, H);
    ctx.fillStyle = '#fff';
    ctx.textAlign = 'center'; ctx.textBaseline = 'middle';
    ctx.shadowColor = 'rgba(0,0,0,0.7)'; ctx.shadowBlur = 8;
    ctx.font = `bold ${Math.round(W * 0.054)}px "Segoe UI",sans-serif`;
    ctx.fillText(IS_PHONE ? 'Swipe to run!' : 'Press ↑↓ or Space to run!', W / 2, H / 2);
    ctx.shadowColor = 'transparent';
  }

  /* ── Screen transitions ── */
  startBtn.addEventListener('click', () => {
    settingsScreen.classList.remove('active');
    gameScreen.classList.add('active');
    startGame();
  });
  settingsBtn.addEventListener('click', () => {
    gameRunning = false;
    cancelAnimationFrame(animId);
    gameScreen.classList.remove('active');
    settingsScreen.classList.add('active');
  });
  overlayBtn.addEventListener('click', startGame);

  let resizeTimer;
  window.addEventListener('resize', () => {
    clearTimeout(resizeTimer);
    resizeTimer = setTimeout(() => {
      if (gameScreen.classList.contains('active') && !gameRunning) { initCanvas(); draw(); }
    }, 100);
  });
})();
</script>
